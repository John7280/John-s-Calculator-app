<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0B1E"
    android:padding="6dp"
    tools:context=".MainActivity">

    <!-- DISPLAY -->
    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:text="@string/btn_0"
        android:textSize="64sp"
        android:textColor="#F5F3FF"
        android:fontFamily="sans-serif-light"
        android:textStyle="bold"
        android:gravity="bottom|end"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp"
        android:background="#0D0B1E"/>

    <!-- ROW 1: sin, cos, tan, π -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal">
        <Button android:id="@+id/btnSin" android:text="@string/btn_sin"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#5EEAD4"/>
        <Button android:id="@+id/btnCos" android:text="@string/btn_cos"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#5EEAD4"/>
        <Button android:id="@+id/btnTan" android:text="@string/btn_tan"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#5EEAD4"/>
        <Button android:id="@+id/btnPi" android:text="@string/btn_pi"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#5EEAD4"/>
    </LinearLayout>

    <!-- ROW 2: sinh, cosh, tanh, n! -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal">
        <Button android:id="@+id/btnSinh" android:text="@string/btn_sinh"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#5EEAD4"/>
        <Button android:id="@+id/btnCosh" android:text="@string/btn_cosh"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#5EEAD4"/>
        <Button android:id="@+id/btnTanh" android:text="@string/btn_tanh"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#5EEAD4"/>
        <Button android:id="@+id/btnFactorial" android:text="@string/btn_factorial"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#5EEAD4"/>
    </LinearLayout>

    <!-- ROW 3: log, ln, √, x² -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal">
        <Button android:id="@+id/btnLog" android:text="@string/btn_log"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#5EEAD4"/>
        <Button android:id="@+id/btnLn" android:text="@string/btn_ln"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#5EEAD4"/>
        <Button android:id="@+id/btnSqrt" android:text="@string/btn_sqrt"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#5EEAD4"/>
        <Button android:id="@+id/btnSquare" android:text="@string/btn_square"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#5EEAD4"/>
    </LinearLayout>

    <!-- ROW 4: nPr, nCr, xʸ, EE -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal">
        <Button android:id="@+id/btnNPR" android:text="@string/btn_npr"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#F472B6"/>
        <Button android:id="@+id/btnNCR" android:text="@string/btn_ncr"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#F472B6"/>
        <Button android:id="@+id/btnPower" android:text="@string/btn_power"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#F472B6"/>
        <Button android:id="@+id/btnEE" android:text="@string/btn_ee"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#1A1B2E" android:textColor="#F472B6"/>
    </LinearLayout>

    <!-- ROW 5: C, +/-, %, ÷ -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal">
        <Button android:id="@+id/btnClear" android:text="@string/btn_clear"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="20sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#7C3AED" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnPlusMinus" android:text="@string/btn_plus_minus"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="20sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#7C3AED" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnPercent" android:text="@string/btn_percent"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="20sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#7C3AED" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnDivide" android:text="@string/btn_divide"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#FBBF24" android:textColor="#0D0B1E"/>
    </LinearLayout>

    <!-- ROW 6: 7, 8, 9, × -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal">
        <Button android:id="@+id/btn7" android:text="@string/btn_7"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#23243A" android:textColor="#F5F3FF"/>
        <Button android:id="@+id/btn8" android:text="@string/btn_8"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#23243A" android:textColor="#F5F3FF"/>
        <Button android:id="@+id/btn9" android:text="@string/btn_9"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#23243A" android:textColor="#F5F3FF"/>
        <Button android:id="@+id/btnMultiply" android:text="@string/btn_multiply"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#FBBF24" android:textColor="#0D0B1E"/>
    </LinearLayout>

    <!-- ROW 7: 4, 5, 6, - -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal">
        <Button android:id="@+id/btn4" android:text="@string/btn_4"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#23243A" android:textColor="#F5F3FF"/>
        <Button android:id="@+id/btn5" android:text="@string/btn_5"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#23243A" android:textColor="#F5F3FF"/>
        <Button android:id="@+id/btn6" android:text="@string/btn_6"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#23243A" android:textColor="#F5F3FF"/>
        <Button android:id="@+id/btnSubtract" android:text="@string/btn_subtract"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#FBBF24" android:textColor="#0D0B1E"/>
    </LinearLayout>

    <!-- ROW 8: 1, 2, 3, + -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal">
        <Button android:id="@+id/btn1" android:text="@string/btn_1"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#23243A" android:textColor="#F5F3FF"/>
        <Button android:id="@+id/btn2" android:text="@string/btn_2"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#23243A" android:textColor="#F5F3FF"/>
        <Button android:id="@+id/btn3" android:text="@string/btn_3"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#23243A" android:textColor="#F5F3FF"/>
        <Button android:id="@+id/btnAdd" android:text="@string/btn_add"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#FBBF24" android:textColor="#0D0B1E"/>
    </LinearLayout>

    <!-- ROW 9: 0, ., = -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal">
        <Button android:id="@+id/btn0" android:text="@string/btn_0"
            android:layout_width="0dp" android:layout_weight="2"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#23243A" android:textColor="#F5F3FF"/>
        <Button android:id="@+id/btnDot" android:text="@string/btn_dot"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#23243A" android:textColor="#F5F3FF"/>
        <Button android:id="@+id/btnEquals" android:text="@string/btn_equals"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:layout_margin="3dp"
            android:textSize="26sp" android:textStyle="bold"
            android:background="@drawable/btn_rounded"
            android:backgroundTint="#FBBF24" android:textColor="#0D0B1E"/>
    </LinearLayout>

</LinearLayout>
